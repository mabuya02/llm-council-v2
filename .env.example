# ──────────────────────────────────────────────────
# LLM Council – Environment Variables
# Copy this file to .env and update values as needed
# ──────────────────────────────────────────────────

# ── Ollama Mode ──────────────────────────────────
# "local" = local Ollama instance, "cloud" = Ollama Cloud API
OLLAMA_MODE=local

# ── Local Ollama ─────────────────────────────────
# Base URL for local Ollama (supports /api/chat and /api/generate)
OLLAMA_API_URL=http://localhost:11434

# ── Cloud Ollama ─────────────────────────────────
# Required when OLLAMA_MODE=cloud
OLLAMA_CLOUD_API_URL=https://ollama.com/api/chat
OLLAMA_CLOUD_API_KEY=

# ── Council Models ───────────────────────────────
# Comma-separated list of models for the council
COUNCIL_MODELS=llama3.2:3b,llama3.1:8b

# Chairman model (defaults to first council model)
CHAIRMAN_MODEL=llama3.2:3b

# Model used to generate conversation titles
TITLE_MODEL=llama3.2:3b

# ── Storage ──────────────────────────────────────
DATA_DIR=data/conversations

# ── Server ───────────────────────────────────────
# Comma-separated CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Reliability ──────────────────────────────────
# Number of retries when a model query fails (0 = no retries)
MODEL_QUERY_MAX_RETRIES=1

# ── Provider (future) ───────────────────────────
# Only "ollama" is supported today
LLM_PROVIDER=ollama

# ── Frontend (set in frontend/.env or as env var) ─
# VITE_API_BASE=http://localhost:8001
